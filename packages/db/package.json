{
  "name": "@medspa/db",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./schema": {
      "types": "./dist/schema.d.ts",
      "default": "./dist/schema.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "push": "drizzle-kit push",
    "generate": "drizzle-kit generate",
    "seed": "tsx seed.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.36.0",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.28.0",
    "dotenv": "^16.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
